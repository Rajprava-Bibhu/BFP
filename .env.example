# =============================================================
# BFP — Business Flow Pro | Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────
# Local:     postgresql://USER:PASSWORD@localhost:5432/bfp
# Hostinger: postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Supabase:  postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
# AWS RDS:   postgresql://USER:PASSWORD@HOST.rds.amazonaws.com:5432/bfp?sslmode=require
DATABASE_URL=postgresql://bfp_user:CHANGE_ME@localhost:5432/bfp

# ── JWT Authentication ───────────────────────────────────────
# Generate secrets with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_a_strong_64_char_secret_here
REFRESH_SECRET=CHANGE_ME_generate_another_strong_64_char_secret
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# ── Frontend (Vite build-time only) ─────────────────────────
# Used during "pnpm run build" only — not needed at runtime
BASE_PATH=/
VITE_API_BASE_URL=https://bfp-backend-reye.onrender.com

# ── AWS S3 — File/Document Storage (optional) ───────────────
# Leave blank if not using file uploads / S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=bfp-uploads
S3_BUCKET_REGION=ap-south-1
S3_CDN_URL=

# ── Email (optional) ─────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
